# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
NEXT_PUBLIC_SITE_URL=https://app.vimmoai.com

# Server-only variables. Never prefix these with NEXT_PUBLIC_.
OPENAI_ANALYSIS_ENABLED=false
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.6-terra
VIMMOAI_ADMIN_USER_ID=your-supabase-auth-user-id

# Keep paid video generation disabled until production safety checks pass.
KLING_GENERATION_ENABLED=false
KLING_API_BASE_URL=https://api-singapore.klingai.com
KLING_API_KEY=your-kling-api-key
